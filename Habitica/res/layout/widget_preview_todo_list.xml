<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_preview_dailies_tile"
    android:orientation="vertical"
    android:paddingHorizontal="10dp"
    android:paddingVertical="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Your To Do's"
            android:textSize="22sp"
            android:textFontWeight="500"
            android:textColor="@color/widget_preview_scallop_glyph_tint" />
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/widget_icon_add"
            android:contentDescription="@null" />
    </LinearLayout>

    <Space android:layout_width="match_parent" android:layout_height="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/widget_preview_row_card"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <View
            android:layout_width="44dp"
            android:layout_height="match_parent"
            android:background="@drawable/widget_preview_tab_left_blue" />
        <Space android:layout_width="10dp" android:layout_height="match_parent" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pick up groceries"
            android:textSize="14sp"
            android:textFontWeight="500"
            android:textColor="@color/widget_preview_scallop_glyph_tint" />
    </LinearLayout>

    <Space android:layout_width="match_parent" android:layout_height="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/widget_preview_row_card"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <View
            android:layout_width="44dp"
            android:layout_height="match_parent"
            android:background="@drawable/widget_preview_tab_left_yellow" />
        <Space android:layout_width="10dp" android:layout_height="match_parent" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email the team"
            android:textSize="14sp"
            android:textFontWeight="500"
            android:textColor="@color/widget_preview_scallop_glyph_tint" />
    </LinearLayout>

    <Space android:layout_width="match_parent" android:layout_height="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/widget_preview_row_card"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <View
            android:layout_width="44dp"
            android:layout_height="match_parent"
            android:background="@drawable/widget_preview_tab_left_green" />
        <Space android:layout_width="10dp" android:layout_height="match_parent" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plan weekend trip"
            android:textSize="14sp"
            android:textFontWeight="500"
            android:textColor="@color/widget_preview_scallop_glyph_tint" />
    </LinearLayout>
</LinearLayout>
