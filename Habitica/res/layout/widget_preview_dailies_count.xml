<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/widget_bg"
    android:orientation="vertical"
    android:gravity="bottom|start"
    android:padding="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3"
        android:textSize="50sp"
        android:textStyle="bold"
        android:textColor="@color/widget_dailies_purple" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dailies done"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/widget_text" />

    <Space android:layout_width="match_parent" android:layout_height="10dp" />

    <ProgressBar
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="12dp"
        android:max="5"
        android:progress="3"
        android:progressTint="#FFBE5D"
        android:progressBackgroundTint="@color/widget_progress_track" />

    <Space android:layout_width="match_parent" android:layout_height="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2 left to do"
        android:textSize="12sp"
        android:textColor="@color/widget_text_secondary" />
</LinearLayout>
