<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/widget_preview_dailies_tile"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="@color/widget_preview_scallop_glyph_tint" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dailies done"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/widget_preview_scallop_glyph_tint" />
        </LinearLayout>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:src="@drawable/widget_progress_squiggle_preview"
            android:contentDescription="@null" />

        <Space android:layout_width="match_parent" android:layout_height="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="11 left to do"
            android:textSize="11sp"
            android:textColor="@color/widget_preview_scallop_glyph_tint" />
    </LinearLayout>
</FrameLayout>
